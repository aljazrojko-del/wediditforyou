# Copy to .env.local and fill in real values. Never commit .env.local.

# Google Places API (New) — for the lead-pull script.
# Get one at: https://console.cloud.google.com → enable "Places API (New)" → Credentials → API key
GOOGLE_PLACES_API_KEY=

# Supabase — backend writes from the lead-pull script.
# From your project: Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: GoHighLevel webhook for forwarding leads from /api/lead.
# When set, the contact form will POST leads here in addition to logging.
GHL_WEBHOOK_URL=

# --- Google Places budget guardrails (lead-pull script only) ---
# Defaults are conservative. Override once you confirm your actual SKU pricing
# in the Google Cloud Console.
#   PLACES_COST_PER_CALL_USD   per-request cost in USD                  (default 0.04)
#   PLACES_MONTHLY_BUDGET_USD  free Maps Platform credit per month      (default 200)
#   PLACES_WARN_AT             warn at this fraction of budget (0..1)   (default 0.80)
#   PLACES_HARD_CAP_AT         refuse to call API at/above this fraction (default 0.90)
PLACES_COST_PER_CALL_USD=0.04
PLACES_MONTHLY_BUDGET_USD=200
PLACES_WARN_AT=0.80
PLACES_HARD_CAP_AT=0.90
